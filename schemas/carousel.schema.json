{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viral-carousel-maker.local/schemas/carousel.schema.json",
  "title": "Viral Carousel Maker Spec",
  "type": "object",
  "required": ["title", "handle", "template_family", "aspect_ratio", "slides"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "title": { "type": "string", "minLength": 1 },
    "handle": { "type": "string", "minLength": 1 },
    "template_family": {
      "type": "string",
      "enum": ["story", "list", "framework", "timeline", "debate", "examples", "data", "quote", "map", "mistakes", "recap", "cta"]
    },
    "aspect_ratio": {
      "type": "string",
      "enum": ["vertical", "square", "wide"]
    },
    "design_pack": {
      "type": "string",
      "enum": [
        "editorial-paper",
        "brutal-proof",
        "quiet-luxury",
        "founder-field-notes",
        "photo-anchor",
        "data-lab",
        "myth-truth",
        "template-marketplace"
      ]
    },
    "render_engine": {
      "type": "string",
      "enum": ["browser", "pillow", "imagegen"]
    },
    "render_quality": {
      "type": "string",
      "enum": ["standard", "high", "ultra"]
    },
    "visual_qa": {
      "type": "object",
      "additionalProperties": true
    },
    "critic": {
      "type": "object",
      "additionalProperties": true
    },
    "pattern_bank": {
      "type": "object",
      "additionalProperties": true
    },
    "learning": {
      "type": "object",
      "additionalProperties": true
    },
    "theme": {
      "type": "object",
      "properties": {
        "palette": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "design_pack": {
          "type": "string"
        },
        "design_tokens": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "profile": {
      "type": "object",
      "additionalProperties": true
    },
    "strategy": {
      "type": "object",
      "properties": {
        "goal": { "type": "string", "enum": ["reach", "saves", "conversion", "authority", "community"] },
        "hook_archetype": { "type": "string" },
        "belief_shift": { "type": "string" },
        "proof_level": { "type": "string", "enum": ["none", "lived-experience", "example", "data", "receipt"] },
        "cta_pressure": { "type": "string", "enum": ["none", "soft", "medium", "hard"] },
        "visual_priority": { "type": "string", "enum": ["standard", "high", "extreme", "thumbnail"] },
        "visual_thesis": { "type": "string" },
        "design_pack": { "type": "string" },
        "virality_principles": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "caption": { "type": "string" },
    "cta": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["follow", "offer"] },
        "url": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "slides": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["role", "title"],
        "properties": {
          "id": { "type": "string" },
          "role": { "type": "string", "enum": ["hook", "body", "recap", "cta"] },
          "title": { "type": "string", "minLength": 1 },
          "subtitle": { "type": "string" },
          "body": { "type": "string" },
          "badge": { "type": "string" },
          "main_idea": { "type": "string" },
          "visual_mode": {
            "type": "string",
            "enum": [
              "editorial-paper",
              "shock-stat",
              "proof-grid",
              "myth-truth",
              "taxonomy",
              "quiet-truth",
              "receipt",
              "contrast-table",
              "field-note",
              "photo-anchor"
            ]
          },
          "visual_prompt": { "type": "string" },
          "alt": { "type": "string" },
          "bullets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "logo": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "domain": { "type": "string" }
            },
            "additionalProperties": true
          },
          "cta": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
